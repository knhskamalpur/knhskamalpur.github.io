---
interface Props {
  title: string;
  activePage: 'dashboard' | 'registration' | 'questions' | 'candidates';
}

const { title, activePage } = Astro.props;

const navItems = [
  { key: 'dashboard',    href: '/apps/examDemo/admin/dashboard',    icon: 'fa-tachometer-alt',  label: 'Dashboard'    },
  { key: 'registration', href: '/apps/examDemo/admin/registration', icon: 'fa-user-plus',        label: 'Registration' },
  { key: 'questions',    href: '/apps/examDemo/admin/questions',    icon: 'fa-question-circle',  label: 'Questions'    },
  { key: 'candidates',   href: '/apps/examDemo/admin/candidates',   icon: 'fa-users',            label: 'Candidates'   },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} — Admin Panel</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    :root { --exam-primary: #0d2e5e; --exam-accent: #e8a000; }
    body { background: #edf0f7; font-family: 'Segoe UI', sans-serif; min-height: 100vh; }

    /* ── Admin Navbar ── */
    .admin-nav {
      background: var(--exam-primary);
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      display: flex; align-items: center; padding: 0 20px; flex-wrap: wrap; min-height: 56px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    .admin-nav .brand { color: #fff; font-weight: 800; font-size: 1.05rem; flex: 1; }
    .admin-nav .badge-admin {
      background: var(--exam-accent); color: #000;
      border-radius: 12px; padding: 2px 10px;
      font-size: 0.72rem; font-weight: 800; margin-right: 12px;
    }
    .nav-links { display: flex; gap: 4px; }
    .nav-links a {
      color: rgba(255,255,255,0.75); text-decoration: none;
      padding: 6px 12px; border-radius: 6px; font-size: 0.85rem; font-weight: 600;
      transition: all 0.15s;
    }
    .nav-links a:hover, .nav-links a.active { background: rgba(255,255,255,0.15); color: #fff; }
    .nav-links a .fa { margin-right: 5px; }
    .btn-logout {
      background: rgba(220,53,69,0.8); color: #fff; border: none;
      border-radius: 6px; padding: 5px 12px; font-size: 0.82rem;
      font-weight: 700; cursor: pointer; margin-left: 8px;
    }
    .btn-logout:hover { background: #dc3545; }
    .nav-toggle { display: none; background: none; border: none; color: #fff; font-size: 1.3rem; cursor: pointer; }
    @media(max-width:680px) {
      .nav-links, .badge-admin { display: none; }
      .nav-toggle { display: block; }
      .nav-links { width: 100%; flex-direction: column; gap: 2px; padding: 6px 0 4px; }
    }

    .spacer { height: 68px; }
    footer { text-align: center; padding: 20px; color: #888; font-size: 0.8rem; margin-top: 20px; }
    .spinner-border { width: 1.1rem; height: 1.1rem; border-width: 2px; }
  </style>
  <slot name="head" />
</head>
<body>

  <nav class="admin-nav">
    <div class="brand"><i class="fa fa-graduation-cap me-2"></i>aPanel</div>
    <span class="badge-admin">ADMIN</span>
    <div class="nav-links" id="navLinks">
      {navItems.map(item => (
        <a href={item.href} class={activePage === item.key ? 'active' : undefined}>
          <i class:list={['fa', item.icon]}></i>{item.label}
        </a>
      ))}
    </div>
    <button class="btn-logout" onclick="adminLogout()">
      <i class="fa fa-sign-out-alt me-1"></i>Logout
    </button>
    <button class="nav-toggle" onclick="toggleNav()"><i class="fa fa-bars"></i></button>
  </nav>
  <div class="spacer"></div>

  <slot />

  <footer>Copyright &copy; KNHS &mdash; Admin Panel</footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script is:inline>
    function toggleNav() {
      const nl = document.getElementById('navLinks');
      nl.style.display = nl.style.display === 'flex' ? 'none' : 'flex';
    }
    function showAlert(type, msg) {
      const el = document.getElementById('alertArea');
      if (!el) return;
      el.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show py-2" role="alert">
        ${msg}
        <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
      </div>`;
    }
    function adminLogout() {
      // API INTEGRATION POINT: sessionStorage.removeItem('adminToken');
      window.location.href = '/apps/examDemo/admin/';
    }
  </script>
  <slot name="scripts" />

</body>
</html>
