---
// examDemo - Admin Login (admin/index.php equivalent)
// API Integration Points:
//   POST /api/exam/admin-login  { id: string, password: string }
//   → { success: boolean, token: string } | { success: false, error: string }
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin Login — Exam Panel</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    :root { --exam-primary: #0d2e5e; --exam-accent: #e8a000; }
    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #b6b6b6 0%, #bdbdbd 50%, #c1c1c1 100%);
      display: flex; flex-direction: column;
      font-family: 'Segoe UI', sans-serif;
    }
    .brand-bar {
      padding: 14px 24px;
      background: #002b5c;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      display: flex; align-items: center; gap: 12px;
    }
    .logo {
        width: 40px;
        height: 40px;
        display: block;
        filter: drop-shadow(0 -1px 11px rgba(255, 255, 255, 0.300));
        transition: all 1.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        transform: perspective(1000px) rotateY(0deg);
    }
    /* .logo:hover {
        transform: perspective(1000px) rotateY(360deg) scale(1.1);
        filter: drop-shadow(0 0 20px rgba(255, 255, 255, 0.5));
    } */
    .brand-bar .title-block h6 { color: #fff; margin: 0; font-weight: 800; }
    .brand-bar .title-block small { color: rgba(255,255,255,0.5); font-size: 0.75rem; }
    .admin-badge {
      background: var(--exam-accent); color: #000;
      padding: 2px 10px; border-radius: 20px;
      font-size: 0.72rem; font-weight: 800; letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .login-wrap {
      flex: 1; display: flex; align-items: center;
      justify-content: center; padding: 40px 16px;
    }
    .login-card {
      background: #fff; border-radius: 16px;
      box-shadow: 0 30px 80px rgba(0,0,0,0.5);
      width: 100%; max-width: 400px; overflow: hidden;
    }
    .card-header-admin {
      background: linear-gradient(135deg, #1a1a2e, #0d2e5e);
      color: #fff; padding: 22px 28px; text-align: center;
    }
    .card-header-admin .icon-circle {
      width: 60px; height: 60px; background: rgba(255,255,255,0.1);
      border: 2px solid rgba(255,255,255,0.2);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      margin: 0 auto 12px; font-size: 1.6rem; color: var(--exam-accent);
    }
    .card-header-admin h4 { margin: 0; font-weight: 800; }
    .card-header-admin p { margin: 6px 0 0; opacity: 0.65; font-size: 0.85rem; }
    .card-body-admin { padding: 28px; }
    .form-label { font-weight: 600; font-size: 0.875rem; color: #333; }
    .form-control { border-radius: 8px; border: 1.5px solid #dde2ec; padding: 10px 14px; }
    .form-control:focus { border-color: var(--exam-primary); box-shadow: 0 0 0 3px rgba(13,46,94,0.12); }
    .password-wrap { position: relative; }
    .toggle-pass {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; color: #888; cursor: pointer; padding: 0;
    }
    .btn-admin-login {
      background: linear-gradient(135deg, #1a1a2e, #0d2e5e);
      color: #fff; border: none; border-radius: 8px;
      padding: 12px; width: 100%;
      font-size: 1rem; font-weight: 700; cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
    }
    .btn-admin-login:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-admin-login:disabled { opacity: 0.5; cursor: not-allowed; }
    .student-link { text-align: center; font-size: 0.85rem; color: #666; margin-top: 16px; }
    .student-link a { color: var(--exam-primary); font-weight: 600; text-decoration: none; }
    footer { background: rgba(0,0,0,0.4); color: rgba(255,255,255,0.4); text-align: center; padding: 10px; font-size: 0.78rem; }
    .spinner-border { width: 1.1rem; height: 1.1rem; border-width: 2px; }
  </style>
</head>
<body>

  <div class="brand-bar">
    <img src="/assets/images/knhs.png" alt="KNHS Logo" width="40" height="40" class="me-2 logo" />
    <div class="title-block">
      <h6>Online Examination Portal</h6>
      <small>Kamalpur Netaji High School</small>
    </div>
    <span class="admin-badge ms-auto">Admin Panel</span>
  </div>

  <div class="login-wrap">
    <div class="login-card">
      <div class="card-header-admin">
        <div class="icon-circle"><i class="fa fa-shield-alt"></i></div>
        <h4>Admin Login</h4>
        <p>Authorised personnel only</p>
      </div>
      <div class="card-body-admin">
        <div id="alertArea" class="mb-3"></div>

        <form id="adminLoginForm" novalidate>
          <div class="mb-3">
            <label class="form-label" for="adminId">Admin ID</label>
            <div class="input-group">
              <span class="input-group-text bg-white"><i class="fa fa-user text-muted"></i></span>
              <input type="text" class="form-control" id="adminId" name="id"
                placeholder="Enter Admin ID" autocomplete="username" required />
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label" for="adminPass">Password</label>
            <div class="input-group password-wrap">
              <span class="input-group-text bg-white"><i class="fa fa-lock text-muted"></i></span>
              <input type="password" class="form-control pe-5" id="adminPass" name="password"
                placeholder="Enter Password" autocomplete="current-password" required />
              <button type="button" class="toggle-pass" id="togglePass"
                onclick="togglePassword()" tabindex="-1">
                <i class="fa fa-eye" id="eyeIcon"></i>
              </button>
            </div>
          </div>

          <button type="submit" class="btn-admin-login" id="loginBtn">
            <span id="loginText"><i class="fa fa-sign-in-alt me-2"></i>Login</span>
            <span id="loginSpinner" class="d-none">
              <span class="spinner-border me-2"></span>Authenticating…
            </span>
          </button>
        </form>

        <div class="student-link">
          <a href="/apps/examDemo/"><i class="fa fa-arrow-left me-1"></i>Student Login</a>
        </div>
      </div>
    </div>
  </div>

  <footer>Copyright (c) KNHS — Admin Portal</footer>

  <script is:inline>
    function togglePassword() {
      const inp  = document.getElementById('adminPass');
      const icon = document.getElementById('eyeIcon');
      if (inp.type === 'password') {
        inp.type = 'text';
        icon.className = 'fa fa-eye-slash';
      } else {
        inp.type = 'password';
        icon.className = 'fa fa-eye';
      }
    }

    document.getElementById('adminLoginForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const id   = document.getElementById('adminId').value.trim();
      const pass = document.getElementById('adminPass').value;
      const alertEl  = document.getElementById('alertArea');
      const loginBtn = document.getElementById('loginBtn');
      const loginText    = document.getElementById('loginText');
      const loginSpinner = document.getElementById('loginSpinner');

      alertEl.innerHTML = '';
      if (!id || !pass) {
        alertEl.innerHTML = '<div class="alert alert-danger py-2">Admin ID and Password cannot be blank.</div>';
        return;
      }

      loginBtn.disabled = true;
      loginText.classList.add('d-none');
      loginSpinner.classList.remove('d-none');

      try {
        // ============================================================
        // API INTEGRATION POINT
        // const res  = await fetch('/api/exam/admin-login', {
        //   method: 'POST',
        //   headers: { 'Content-Type': 'application/json' },
        //   body: JSON.stringify({ id, password: pass })
        // });
        // const data = await res.json();
        // if (data.success) {
        //   // Store token in sessionStorage
        //   sessionStorage.setItem('adminToken', data.token);
        //   window.location.href = '/apps/examDemo/admin/dashboard';
        // } else {
        //   alertEl.innerHTML = `<div class="alert alert-danger py-2">${data.error || 'Invalid credentials.'}</div>`;
        // }
        // ============================================================

        // Stub — remove when API is integrated
        alertEl.innerHTML = '<div class="alert alert-info py-2">API not connected yet. ID: <strong>' + id + '</strong></div>';
      } catch (err) {
        alertEl.innerHTML = '<div class="alert alert-danger py-2">Network error. Please try again.</div>';
      } finally {
        loginBtn.disabled = false;
        loginText.classList.remove('d-none');
        loginSpinner.classList.add('d-none');
      }
    });
  </script>
</body>
</html>
