---
// examDemo - Admin View All Candidates (admin/viewallpro.php equivalent)
// API Integration Points:
//   GET  /api/exam/admin/candidates
//   → { candidates: Array<{ candidate-name, c-o, dob, registration-no, mobile-no, roll-no, exam-date, batch, submitted: boolean }> }
//
//   DELETE /api/exam/admin/candidate?roll={rollNo}
//   → { success: boolean }
//
//   DELETE /api/exam/admin/candidates/all
//   → { success: boolean }
import AdminLayout from '../../../../layouts/AdminLayout.astro';
---
<AdminLayout title="All Candidates" activePage="candidates">
<Fragment slot="head">
  <style>

    /* Toolbar */
    .toolbar {
      background: #fff; border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.07);
      padding: 14px 18px;
      display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
      margin-bottom: 16px;
    }
    .toolbar h5 { margin: 0; color: var(--exam-primary); font-weight: 800; flex: 1; }
    .search-box { border-radius: 8px; border: 1.5px solid #dde2ec; padding: 7px 12px; font-size: 0.9rem; min-width: 220px; }
    .search-box:focus { outline: none; border-color: var(--exam-primary); }
    .btn-add { background: var(--exam-primary); color: #fff; border: none; border-radius: 8px; padding: 8px 16px; font-size: 0.85rem; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
    .btn-add:hover { background: #1a5099; color: #fff; }
    .btn-danger-sm { background: none; border: 1.5px solid #dc3545; color: #dc3545; border-radius: 8px; padding: 7px 14px; font-size: 0.82rem; font-weight: 700; cursor: pointer; }
    .btn-danger-sm:hover { background: #dc3545; color: #fff; }
    .btn-refresh { background: none; border: 1.5px solid #6c757d; color: #6c757d; border-radius: 8px; padding: 7px 14px; font-size: 0.82rem; font-weight: 700; cursor: pointer; }
    .btn-refresh:hover { background: #6c757d; color: #fff; }

    /* Table card */
    .table-card {
      background: #fff; border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07);
      overflow: hidden;
    }
    .table-responsive { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: var(--exam-primary); color: #fff; }
    thead th { padding: 12px 14px; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; border: none; white-space: nowrap; }
    tbody tr { border-bottom: 1px solid #f0f0f0; transition: background 0.1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #f8f9fb; }
    tbody td { padding: 12px 14px; font-size: 0.875rem; color: #333; vertical-align: middle; }
    .name-cell { font-weight: 700; color: #1a1a2e; }
    .roll-badge {
      background: #e8f0fe; color: var(--exam-primary);
      border-radius: 6px; padding: 2px 8px;
      font-size: 0.78rem; font-weight: 800;
    }
    .status-pill {
      padding: 3px 10px; border-radius: 20px;
      font-size: 0.75rem; font-weight: 700; white-space: nowrap;
    }
    .status-submitted { background: #d4edda; color: #155724; }
    .status-pending   { background: #fff3cd; color: #856404; }
    .status-registered { background: #e8f0fe; color: var(--exam-primary); }
    .btn-row-del { background: none; border: none; color: #dc3545; cursor: pointer; padding: 4px 8px; border-radius: 6px; }
    .btn-row-del:hover { background: #f8d7da; }

    /* Empty state */
    .empty-state { padding: 48px; text-align: center; color: #aaa; }
    .empty-state .fa { font-size: 2.5rem; margin-bottom: 12px; color: #dde2ec; }

    /* Stats row */
    .mini-stats { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .mini-stat {
      background: #fff; border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      padding: 10px 18px 10px 14px;
      display: flex; align-items: center; gap: 10px;
    }
    .mini-stat .ms-icon { font-size: 1.2rem; color: var(--exam-primary); }
    .mini-stat .ms-val { font-size: 1.3rem; font-weight: 800; color: #1a1a2e; }
    .mini-stat .ms-lbl { font-size: 0.72rem; color: #888; }

    @media print {
      .admin-nav, .toolbar .btn-add, .toolbar .btn-danger-sm, .toolbar .btn-refresh,
      .btn-row-del, .search-box { display: none !important; }
    }
  </style>
</Fragment>

  <div class="container-fluid px-3 py-2">
    <div id="alertArea" class="mb-3"></div>

    <!-- Mini Stats -->
    <div class="mini-stats" id="miniStats">
      <div class="mini-stat">
        <i class="fa fa-users ms-icon"></i>
        <div><div class="ms-val" id="msTotal">—</div><div class="ms-lbl">Total</div></div>
      </div>
      <div class="mini-stat">
        <i class="fa fa-check-circle ms-icon" style="color:#28a745;"></i>
        <div><div class="ms-val" id="msSubmitted">—</div><div class="ms-lbl">Submitted</div></div>
      </div>
      <div class="mini-stat">
        <i class="fa fa-clock ms-icon" style="color:#e8a000;"></i>
        <div><div class="ms-val" id="msPending">—</div><div class="ms-lbl">Pending</div></div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
      <h5><i class="fa fa-users me-2"></i>All Candidates</h5>
      <input type="text" id="searchInput" class="search-box" placeholder="Search by name or roll no…" oninput="filterTable()" />
      <button class="btn-refresh" onclick="loadCandidates()"><i class="fa fa-sync me-1"></i>Refresh</button>
      <a href="/apps/examDemo/admin/registration" class="btn-add"><i class="fa fa-user-plus"></i>Register New</a>
      <button class="btn-danger-sm" onclick="deleteAll()"><i class="fa fa-trash me-2"></i>Delete All</button>
    </div>

    <!-- Table -->
    <div class="table-card">
      <div class="table-responsive">
        <table id="candidatesTable">
          <thead>
            <tr>
              <th>#</th>
              <th>Candidate Name</th>
              <th>C/O</th>
              <th>Date of Birth</th>
              <th>Reg. No.</th>
              <th>Mobile</th>
              <th>Roll No.</th>
              <th>Exam Date &amp; Time</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr>
              <td colspan="10" class="text-center py-4">
                <span class="spinner-border me-2"></span> Loading candidates…
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div id="emptyState" class="empty-state d-none">
        <i class="fa fa-user-slash"></i>
        <p>No candidates registered yet.</p>
        <a href="/apps/examDemo/admin/registration" class="btn-add" style="display:inline-flex;margin:0 auto;">
          <i class="fa fa-user-plus me-2"></i>Register First Candidate
        </a>
      </div>
    </div>

  </div>

<Fragment slot="scripts">
  <script is:inline>
    let allCandidates = [];

    async function loadCandidates() {
      document.getElementById('tableBody').innerHTML =
        '<tr><td colspan="10" class="text-center py-4"><span class="spinner-border me-2"></span> Loading…</td></tr>';

      try {
        // ============================================================
        // API INTEGRATION POINT
        // const res  = await fetch('/api/exam/admin/candidates', { headers: { 'Authorization': 'Bearer ' + sessionStorage.getItem('adminToken') } });
        // const data = await res.json();
        // allCandidates = data.candidates || [];
        // ============================================================

        // Stub data
        allCandidates = [
          { 'candidate-name': 'Ramesh Kumar',   'c-o': 'Suresh Kumar',  dob: '2000-05-12', 'registration-no': 'REG-001', 'mobile-no': '9876543210', 'roll-no': '101', 'exam-date': '2026-03-09', batch: '10:00', submitted: true  },
          { 'candidate-name': 'Priya Sharma',   'c-o': 'Vinod Sharma',  dob: '2001-08-22', 'registration-no': 'REG-002', 'mobile-no': '9876543211', 'roll-no': '102', 'exam-date': '2026-03-09', batch: '10:00', submitted: false },
          { 'candidate-name': 'Anita Roy',      'c-o': 'Bijoy Roy',     dob: '1999-11-01', 'registration-no': 'REG-003', 'mobile-no': '9123456789', 'roll-no': '103', 'exam-date': '2026-03-09', batch: '10:00', submitted: true  },
          { 'candidate-name': 'Souvik Mondal',  'c-o': 'Tarun Mondal',  dob: '2002-03-17', 'registration-no': 'REG-004', 'mobile-no': '',           'roll-no': '104', 'exam-date': '2026-03-09', batch: '10:00', submitted: false },
        ];

        renderTable(allCandidates);
        updateMiniStats(allCandidates);
      } catch (err) {
        document.getElementById('tableBody').innerHTML =
          '<tr><td colspan="10" class="text-center text-danger py-4">Failed to load candidates.</td></tr>';
      }
    }

    function renderTable(candidates) {
      const tbody = document.getElementById('tableBody');

      if (!candidates.length) {
        tbody.innerHTML = '';
        document.getElementById('emptyState').classList.remove('d-none');
        return;
      }
      document.getElementById('emptyState').classList.add('d-none');

      tbody.innerHTML = candidates.map((c, i) => {
        const statusPill = c.submitted
          ? '<span class="status-pill status-submitted"><i class="fa fa-check me-1"></i>Submitted</span>'
          : '<span class="status-pill status-pending"><i class="fa fa-clock me-1"></i>Pending</span>';
        return `<tr data-name="${c['candidate-name'].toLowerCase()}" data-roll="${c['roll-no']}">
          <td>${i + 1}</td>
          <td class="name-cell">${c['candidate-name']}</td>
          <td>${c['c-o']}</td>
          <td>${c['dob']}</td>
          <td>${c['registration-no']}</td>
          <td>${c['mobile-no'] || '<span class="text-muted">—</span>'}</td>
          <td><span class="roll-badge">${c['roll-no']}</span></td>
          <td>${c['exam-date']} ${c['batch']}</td>
          <td>${statusPill}</td>
          <td>
            <button class="btn-row-del" title="Delete candidate" onclick="deleteCandidate('${c['roll-no']}', '${c['candidate-name']}')">
              <i class="fa fa-trash"></i>
            </button>
          </td>
        </tr>`;
      }).join('');
    }

    function updateMiniStats(candidates) {
      const total     = candidates.length;
      const submitted = candidates.filter(c => c.submitted).length;
      document.getElementById('msTotal').textContent     = total;
      document.getElementById('msSubmitted').textContent = submitted;
      document.getElementById('msPending').textContent   = total - submitted;
    }

    function filterTable() {
      const q = document.getElementById('searchInput').value.toLowerCase();
      const filtered = allCandidates.filter(c =>
        c['candidate-name'].toLowerCase().includes(q) ||
        c['roll-no'].toLowerCase().includes(q)
      );
      renderTable(filtered);
    }

    async function deleteCandidate(roll, name) {
      if (!confirm(`Delete profile of "${name}" (Roll: ${roll})? This will also remove their assigned question paper and answers.`)) return;

      try {
        // ============================================================
        // API INTEGRATION POINT
        // const res  = await fetch(`/api/exam/admin/candidate?roll=${roll}`, { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + sessionStorage.getItem('adminToken') } });
        // const data = await res.json();
        // if (data.success) { loadCandidates(); showAlert('success', `Deleted profile of "${name}".`); }
        // else showAlert('danger', data.error || 'Delete failed.');
        // ============================================================

        showAlert('info', `[Stub] Delete roll: ${roll}`);
      } catch (err) {
        showAlert('danger', 'Network error.');
      }
    }

    async function deleteAll() {
      if (!confirm('⚠️ Delete ALL candidate profiles? This action cannot be undone.')) return;

      try {
        // ============================================================
        // API INTEGRATION POINT
        // const res  = await fetch('/api/exam/admin/candidates/all', { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + sessionStorage.getItem('adminToken') } });
        // const data = await res.json();
        // if (data.success) { loadCandidates(); showAlert('success', 'All profiles deleted.'); }
        // ============================================================

        showAlert('info', '[Stub] Delete all called.');
      } catch (err) {
        showAlert('danger', 'Network error.');
      }
    }

    loadCandidates();
  </script>
</Fragment>
</AdminLayout>
</html>
