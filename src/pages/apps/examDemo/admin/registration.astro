---
// examDemo - Admin Student Registration (admin/registration.php equivalent)
// API Integration Points:
//   GET  /api/exam/admin/next-profile-number
//   → { nextNo: number }
//
//   POST /api/exam/admin/register-candidate
//   Body: { candidate-name, c-o, dob, registration-no, mobile-no, roll-no, exam-date, batch }
//   → { success: boolean, profileNo: number } | { success: false, error: string }
import AdminLayout from '../../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Candidate Registration" activePage="registration">
<Fragment slot="head">
  <style>

    /* Form card */
    .reg-card {
      background: #fff; border-radius: 14px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      max-width: 720px; margin: 0 auto; overflow: hidden;
    }
    .reg-card .rc-header {
      background: var(--exam-primary); color: #fff;
      padding: 16px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .reg-card .rc-header h5 { margin: 0; font-weight: 700; }
    .profile-no-badge {
      background: var(--exam-accent); color: #000;
      border-radius: 20px; padding: 4px 14px;
      font-size: 0.8rem; font-weight: 800;
    }
    .rc-body { padding: 24px; }
    .rc-footer { padding: 16px 24px; background: #f8f9fb; border-top: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }

    .form-label { font-weight: 600; font-size: 0.875rem; color: #333; }
    .form-control { border-radius: 8px; border: 1.5px solid #dde2ec; padding: 10px 14px; }
    .form-control:focus { border-color: var(--exam-primary); box-shadow: 0 0 0 3px rgba(13,46,94,0.12); }
    .form-control.is-invalid { border-color: #dc3545; }
    .required-star { color: #dc3545; }

    .section-title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; color: #888; margin-bottom: 14px; border-bottom: 1px solid #eee; padding-bottom: 8px; }

    .btn-submit-reg {
      background: var(--exam-primary); color: #fff; border: none;
      border-radius: 8px; padding: 10px 28px;
      font-weight: 700; font-size: 0.95rem; cursor: pointer;
    }
    .btn-submit-reg:hover { background: #1a5099; }
    .btn-submit-reg:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn-view-all {
      background: none; border: 1px solid var(--exam-primary); color: var(--exam-primary);
      border-radius: 8px; padding: 8px 16px; font-size: 0.85rem; font-weight: 600;
      text-decoration: none; transition: all 0.15s;
    }
    .btn-view-all:hover { background: var(--exam-primary); color: #fff; }
  </style>
</Fragment>

  <div class="container py-3">
    <div id="alertArea" class="mb-3"></div>

    <div class="reg-card">
      <div class="rc-header">
        <h5><i class="fa fa-user-plus me-2"></i>Candidate Registration</h5>
        <span class="profile-no-badge">Profile No: <span id="profileNo">—</span></span>
      </div>
      <div class="rc-body">

        <form id="regForm" novalidate>
          <!-- Personal Info -->
          <p class="section-title">Personal Information</p>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="candidateName">Candidate Name <span class="required-star">*</span></label>
              <input type="text" class="form-control" id="candidateName" name="candidate-name"
                placeholder="Full name of candidate" required />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="co">C/O (Guardian Name) <span class="required-star">*</span></label>
              <input type="text" class="form-control" id="co" name="c-o"
                placeholder="Father's / Guardian's name" required />
            </div>
            <div class="col-md-4">
              <label class="form-label" for="dob">Date of Birth <span class="required-star">*</span></label>
              <input type="date" class="form-control" id="dob" name="dob" required />
            </div>
            <div class="col-md-4">
              <label class="form-label" for="mobileNo">Mobile Number</label>
              <input type="tel" class="form-control" id="mobileNo" name="mobile-no"
                placeholder="10-digit mobile number"
                pattern="[0-9]{10}" maxlength="10" />
            </div>
            <div class="col-md-4">
              <label class="form-label" for="registrationNo">Registration No <span class="required-star">*</span></label>
              <input type="text" class="form-control" id="registrationNo" name="registration-no"
                placeholder="e.g. REG-001" required />
            </div>
          </div>

          <!-- Exam Info -->
          <p class="section-title mt-4">Exam Schedule</p>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label" for="rollNo">Roll Number <span class="required-star">*</span></label>
              <input type="text" class="form-control" id="rollNo" name="roll-no"
                placeholder="Unique roll number" required />
            </div>
            <div class="col-md-4">
              <label class="form-label" for="examDate">Exam Date <span class="required-star">*</span></label>
              <input type="date" class="form-control" id="examDate" name="exam-date" required />
            </div>
            <div class="col-md-4">
              <label class="form-label" for="batch">Batch / Time <span class="required-star">*</span></label>
              <input type="time" class="form-control" id="batch" name="batch" required />
            </div>
          </div>
        </form>

      </div>
      <div class="rc-footer">
        <a href="/apps/examDemo/admin/candidates" class="btn-view-all">
          <i class="fa fa-list me-2"></i>View All Profiles
        </a>
        <button class="btn-submit-reg" id="submitBtn" onclick="submitRegistration()">
          <span id="submitText"><i class="fa fa-save me-2"></i>Save &amp; Register</span>
          <span id="submitSpinner" class="d-none">
            <span class="spinner-border me-2"></span>Saving…
          </span>
        </button>
      </div>
    </div>
  </div>

<Fragment slot="scripts">
  <script is:inline>
    async function loadProfileNumber() {
      try {
        // ============================================================
        // API INTEGRATION POINT
        // const res  = await fetch('/api/exam/admin/next-profile-number', { headers: { 'Authorization': 'Bearer ' + sessionStorage.getItem('adminToken') } });
        // const data = await res.json();
        // document.getElementById('profileNo').textContent = data.nextNo;
        // ============================================================

        // Stub
        document.getElementById('profileNo').textContent = '?? (API pending)';
      } catch (err) { /* non-critical */ }
    }

    async function submitRegistration() {
      const form    = document.getElementById('regForm');
      const alertEl = document.getElementById('alertArea');
      alertEl.innerHTML = '';

      // Basic client-side validation
      const required = ['candidateName', 'co', 'dob', 'registrationNo', 'rollNo', 'examDate', 'batch'];
      let valid = true;
      required.forEach(id => {
        const el = document.getElementById(id);
        if (!el.value.trim()) { el.classList.add('is-invalid'); valid = false; }
        else el.classList.remove('is-invalid');
      });
      if (!valid) {
        alertEl.innerHTML = '<div class="alert alert-danger py-2">Please fill in all required fields.</div>';
        return;
      }

      const btn         = document.getElementById('submitBtn');
      const submitText  = document.getElementById('submitText');
      const submitSpin  = document.getElementById('submitSpinner');
      btn.disabled = true;
      submitText.classList.add('d-none');
      submitSpin.classList.remove('d-none');

      const data = {
        'candidate-name':  document.getElementById('candidateName').value.trim(),
        'c-o':             document.getElementById('co').value.trim(),
        'dob':             document.getElementById('dob').value,
        'registration-no': document.getElementById('registrationNo').value.trim(),
        'mobile-no':       document.getElementById('mobileNo').value.trim(),
        'roll-no':         document.getElementById('rollNo').value.trim(),
        'exam-date':       document.getElementById('examDate').value,
        'batch':           document.getElementById('batch').value,
      };

      try {
        // ============================================================
        // API INTEGRATION POINT
        // const res  = await fetch('/api/exam/admin/register-candidate', {
        //   method: 'POST',
        //   headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + sessionStorage.getItem('adminToken') },
        //   body: JSON.stringify(data)
        // });
        // const resp = await res.json();
        // if (resp.success) {
        //   showAlert('success', `Profile #${resp.profileNo} saved for <strong>${data['candidate-name']}</strong>.`);
        //   document.getElementById('regForm').reset();
        //   loadProfileNumber();
        // } else {
        //   showAlert('danger', resp.error || 'Registration failed.');
        // }
        // ============================================================

        // Stub
        showAlert('info', '[Stub] Data logged to console. API not connected yet.');
        console.log('Registration payload:', data);
      } catch (err) {
        showAlert('danger', 'Network error. Please try again.');
      } finally {
        btn.disabled = false;
        submitText.classList.remove('d-none');
        submitSpin.classList.add('d-none');
      }
    }

    function toggleNav() {
      const nl = document.getElementById('navLinks');
      nl.style.display = nl.style.display === 'flex' ? 'none' : 'flex';
    }

    // Scroll to top after alert on this page
    const _baseShowAlert = showAlert;
    function showAlert(type, msg) {
      _baseShowAlert(type, msg);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Clear validation styles on input
    document.querySelectorAll('.form-control').forEach(el => {
      el.addEventListener('input', () => el.classList.remove('is-invalid'));
    });

    loadProfileNumber();
  </script>
</Fragment>
</AdminLayout>
