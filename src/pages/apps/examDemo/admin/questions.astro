    // ── Create Set ────────────────────────────────────────────────────────
    async function createSet() {
      const name   = document.getElementById('newSetName').value.trim();
      const alertEl = document.getElementById('newSetAlert');
      alertEl.innerHTML = '';

      if (!name) { alertEl.innerHTML = '<div class="alert alert-danger py-1">Set name is required.</div>'; return; }
      if (!/^[A-Za-z0-9\-_]+$/.test(name)) {
        alertEl.innerHTML = '<div class="alert alert-danger py-1">Only letters, numbers, hyphens and underscores allowed.</div>';
        return;
      }

      const btn = document.getElementById('btnCreateSet');
      btn.disabled = true;
      document.getElementById('createSetText').textContent = '';
      document.getElementById('createSetSpin').classList.remove('d-none');

      try {
        // ============================================================
        // API INTEGRATION POINT
        // const res  = await fetch('/api/exam/admin/create-question-set', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + sessionStorage.getItem('adminToken') }, body: JSON.stringify({ name }) });
        // const data = await res.json();
        // if (data.success) { bootstrap.Modal.getInstance(document.getElementById('newSetModal')).hide(); loadSets(); selectSet(name); }
        // else { alertEl.innerHTML = `<div class="alert alert-danger py-1">${data.error || 'Error.'}</div>`; }
        // ============================================================

        bootstrap.Modal.getInstance(document.getElementById('newSetModal')).hide();
        showAlert('info', `[Stub] Create set: "${name}".`);
        document.getElementById('newSetName').value = '';
      } catch (err) {
        alertEl.innerHTML = '<div class="alert alert-danger py-1">Network error.</div>';
      } finally {
        btn.disabled = false;
        document.getElementById('createSetText').textContent = 'Create';
        document.getElementById('createSetSpin').classList.add('d-none');
      }
    }

    function showAlert(type, msg) {
      document.getElementById('alertArea').innerHTML =
        `<div class="alert alert-${type} alert-dismissible fade show py-2">
          ${msg}
          <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
        </div>`;
    }

    loadSets();
  </script>
