---
// examDemo - Report Card / Result Page (result.php equivalent)
// API Integration Points:
//   POST /api/exam/result  { roll: string, dob: string }
//   → { success: boolean, student: {...}, result: { correct: number, wrong: number, total: number, sections: [...] } }
//    | { success: false, error: string }
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Report Card — Online Examination</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    :root { --exam-primary: #0d2e5e; --exam-accent: #e8a000; }
    body { background: #f0f3f9; font-family: 'Segoe UI', sans-serif; min-height: 100vh; }

    .brand-bar {
      background: var(--exam-primary); color: #fff;
      padding: 12px 24px; display: flex; align-items: center; gap: 12px;
    }
    .brand-bar h6 { margin: 0; font-weight: 800; font-size: 1rem; }
    .brand-bar small { opacity: 0.7; }

    /* ── Login Form ── */
    .login-card {
      background: #fff; border-radius: 14px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      max-width: 420px; width: 100%; overflow: hidden;
    }
    .lc-header { background: var(--exam-primary); color: #fff; padding: 18px 24px; }
    .lc-header h5 { margin: 0; font-weight: 700; }
    .lc-header p { margin: 6px 0 0; opacity: 0.7; font-size: 0.85rem; }
    .lc-body { padding: 24px; }
    .form-label { font-weight: 600; font-size: 0.875rem; }
    .form-control { border-radius: 8px; border: 1.5px solid #dde2ec; }
    .form-control:focus { border-color: var(--exam-primary); box-shadow: 0 0 0 3px rgba(13,46,94,0.12); }
    .btn-fetch {
      background: var(--exam-primary); color: #fff; border: none;
      border-radius: 8px; padding: 11px; width: 100%;
      font-weight: 700; font-size: 1rem; cursor: pointer;
    }
    .btn-fetch:hover { background: #1a5099; }
    .btn-fetch:disabled { opacity: 0.6; cursor: not-allowed; }

    /* ── Report Card ── */
    .report-card {
      background: #fff; border-radius: 14px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      max-width: 720px; width: 100%; overflow: hidden;
    }
    .rc-header {
      background: var(--exam-primary); color: #fff;
      padding: 18px 24px;
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    }
    .rc-header h5 { margin: 0; font-weight: 700; }
    .rc-actions { display: flex; gap: 8px; }
    .rc-actions button {
      border: none; border-radius: 6px; padding: 6px 14px;
      font-size: 0.85rem; font-weight: 600; cursor: pointer;
    }
    .btn-close-card { background: rgba(255,255,255,0.2); color: #fff; }
    .btn-print       { background: var(--exam-accent); color: #000; }

    .info-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0; border-bottom: 1px solid #eee;
    }
    .info-cell {
      padding: 12px 18px; border-right: 1px solid #eee;
    }
    .info-cell:last-child { border-right: none; }
    .info-cell .lbl { font-size: 0.75rem; color: #888; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .info-cell .val { font-size: 1rem; font-weight: 700; color: #1a1a2e; margin-top: 2px; }

    .score-bar {
      display: flex; gap: 0;
      background: #f8f9fb; border-bottom: 1px solid #eee;
    }
    .score-cell {
      flex: 1; text-align: center; padding: 18px 10px;
      border-right: 1px solid #eee;
    }
    .score-cell:last-child { border-right: none; }
    .score-cell .score-val { font-size: 2rem; font-weight: 800; }
    .score-cell .score-lbl { font-size: 0.8rem; color: #666; margin-top: 4px; }
    .score-correct   .score-val { color: #28a745; }
    .score-wrong     .score-val { color: #dc3545; }
    .score-unattempt .score-val { color: #6c757d; }
    .score-total     .score-val { color: var(--exam-primary); }

    /* Section-wise details */
    .sec-table { padding: 16px; }
    .sec-table table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .sec-table th {
      background: var(--exam-primary); color: #fff;
      padding: 10px 14px; text-align: left; font-weight: 700;
    }
    .sec-table td { padding: 10px 14px; border-bottom: 1px solid #eee; }
    .sec-table tr:last-child td { border-bottom: none; }
    .sec-table tr:nth-child(even) td { background: #f8f9fb; }

    @media print {
      .rc-actions, .btn-fetch, #loginForm, .brand-bar, .no-print { display: none !important; }
      .report-card { box-shadow: none; border: 1px solid #ccc; }
      body { background: #fff; }
    }

    footer { text-align: center; padding: 20px; color: #888; font-size: 0.8rem; margin-top: 20px; }
    .spinner-border { width: 1.1rem; height: 1.1rem; border-width: 2px; }
  </style>
</head>
<body>

  <div class="brand-bar">
    <i class="fa fa-graduation-cap fa-lg me-1"></i>
    <div>
      <h6>Online Examination Portal</h6>
      <small>Kamalpur Netaji HIght School</small>
    </div>
  </div>

  <div class="container py-4">

    <!-- ── Fetch Form ── -->
    <div class="d-flex justify-content-center" id="formSection">
      <div class="login-card">
        <div class="lc-header">
          <h5><i class="fa fa-file-alt me-2"></i>Report Card Download</h5>
          <p>Organised by Mahamaya CSC</p>
        </div>
        <div class="lc-body">
          <div id="alertArea" class="mb-3"></div>
          <form id="loginForm" novalidate>
            <div class="mb-3">
              <label class="form-label" for="rollNo">Roll Number</label>
              <div class="input-group">
                <span class="input-group-text bg-white"><i class="fa fa-id-card text-muted"></i></span>
                <input type="text" class="form-control" id="rollNo" placeholder="Enter Roll Number" required />
              </div>
            </div>
            <div class="mb-4">
              <label class="form-label" for="dob">Date of Birth</label>
              <div class="input-group">
                <span class="input-group-text bg-white"><i class="fa fa-calendar text-muted"></i></span>
                <input type="date" class="form-control" id="dob" required />
              </div>
            </div>
            <button type="submit" class="btn-fetch" id="fetchBtn">
              <span id="fetchText"><i class="fa fa-download me-2"></i>Fetch Report Card</span>
              <span id="fetchSpinner" class="d-none">
                <span class="spinner-border me-2"></span>Loading…
              </span>
            </button>
          </form>
          <div class="text-center mt-3 no-print">
            <small><a href="/apps/examDemo/" style="color:var(--exam-primary);">← Back to Login</a></small>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Report Card (hidden until fetched) ── -->
    <div class="d-flex justify-content-center d-none" id="reportSection">
      <div class="report-card">
        <div class="rc-header">
          <h5><i class="fa fa-certificate me-2"></i>Report Card — Mahamaya CSC Online Exam</h5>
          <div class="rc-actions no-print">
            <button class="btn-close-card" onclick="closeReport()"><i class="fa fa-times me-1"></i>Close</button>
            <button class="btn-print" onclick="window.print()"><i class="fa fa-print me-1"></i>Print</button>
          </div>
        </div>

        <!-- Student info -->
        <div class="info-grid" id="infoGrid">
          <!-- injected by JS -->
        </div>

        <!-- Score summary -->
        <div class="score-bar">
          <div class="score-cell score-correct">
            <div class="score-val" id="scoreCorrect">—</div>
            <div class="score-lbl">Correct</div>
          </div>
          <div class="score-cell score-wrong">
            <div class="score-val" id="scoreWrong">—</div>
            <div class="score-lbl">Wrong</div>
          </div>
          <div class="score-cell score-unattempt">
            <div class="score-val" id="scoreUnattempt">—</div>
            <div class="score-lbl">Unattempted</div>
          </div>
          <div class="score-cell score-total">
            <div class="score-val" id="scoreTotal">—</div>
            <div class="score-lbl">Total Questions</div>
          </div>
        </div>

        <!-- Section-wise -->
        <div class="sec-table" id="secTable"></div>
      </div>
    </div>

  </div>

  <footer class="no-print">Copyright (c) KNHS</footer>

  <script is:inline>
    document.getElementById('loginForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const roll    = document.getElementById('rollNo').value.trim();
      const dob     = document.getElementById('dob').value;
      const alert   = document.getElementById('alertArea');
      const fetchBtn     = document.getElementById('fetchBtn');
      const fetchText    = document.getElementById('fetchText');
      const fetchSpinner = document.getElementById('fetchSpinner');

      alert.innerHTML = '';
      if (!roll || !dob) {
        alert.innerHTML = '<div class="alert alert-danger py-2">Please fill in all fields.</div>';
        return;
      }

      fetchBtn.disabled = true;
      fetchText.classList.add('d-none');
      fetchSpinner.classList.remove('d-none');

      try {
        // ============================================================
        // API INTEGRATION POINT
        // const res  = await fetch('/api/exam/result', {
        //   method: 'POST',
        //   headers: { 'Content-Type': 'application/json' },
        //   body: JSON.stringify({ roll, dob })
        // });
        // const data = await res.json();
        // if (!data.success) {
        //   alert.innerHTML = `<div class="alert alert-danger py-2">${data.error || 'Invalid credentials.'}</div>`;
        // } else {
        //   renderReport(data.student, data.result);
        // }
        // ============================================================

        // Stub — remove when API is integrated
        alert.innerHTML = '<div class="alert alert-info py-2">API not connected yet.</div>';
      } catch (err) {
        alert.innerHTML = '<div class="alert alert-danger py-2">Network error. Please try again.</div>';
      } finally {
        fetchBtn.disabled = false;
        fetchText.classList.remove('d-none');
        fetchSpinner.classList.add('d-none');
      }
    });

    function renderReport(student, result) {
      // Student info grid
      const fields = [
        { lbl: 'Candidate Name', val: student['candidate-name'] },
        { lbl: 'C/O',            val: student['c-o'] },
        { lbl: 'Date of Birth',  val: student['dob'] },
        { lbl: 'Registration No',val: student['registration-no'] },
        { lbl: 'Roll Number',    val: student['roll-no'] },
        { lbl: 'Exam Date-Time', val: student['exam-date'] + ' ' + student['batch'] },
      ];
      document.getElementById('infoGrid').innerHTML = fields.map(f =>
        `<div class="info-cell"><div class="lbl">${f.lbl}</div><div class="val">${f.val}</div></div>`
      ).join('');

      // Scores
      document.getElementById('scoreCorrect').textContent   = result.correct;
      document.getElementById('scoreWrong').textContent     = result.wrong;
      document.getElementById('scoreUnattempt').textContent = result.total - result.correct - result.wrong;
      document.getElementById('scoreTotal').textContent     = result.total;

      // Section-wise table
      if (result.sections && result.sections.length) {
        let tableHTML = `<table>
          <thead><tr><th>Section</th><th>Correct</th><th>Wrong</th><th>Unattempted</th><th>Total</th></tr></thead>
          <tbody>`;
        result.sections.forEach(sec => {
          tableHTML += `<tr>
            <td>${sec.name}</td>
            <td style="color:#28a745;font-weight:700;">${sec.correct}</td>
            <td style="color:#dc3545;font-weight:700;">${sec.wrong}</td>
            <td>${sec.total - sec.correct - sec.wrong}</td>
            <td>${sec.total}</td>
          </tr>`;
        });
        tableHTML += '</tbody></table>';
        document.getElementById('secTable').innerHTML = tableHTML;
      }

      document.getElementById('formSection').classList.add('d-none');
      document.getElementById('reportSection').classList.remove('d-none');
      document.title = 'Report Card — ' + student['candidate-name'];
    }

    function closeReport() {
      document.getElementById('reportSection').classList.add('d-none');
      document.getElementById('formSection').classList.remove('d-none');
      document.getElementById('alertArea').innerHTML = '';
    }
  </script>
</body>
</html>
