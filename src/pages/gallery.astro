---
import BaseLayout from '../layouts/BaseLayout.astro'

const description = "Explore the vibrant life at Kamalpur Netaji High School (H.S.) through our photo gallery, featuring campus events, students, and school activities.";

const images = [
  "114243.jpg", "119825.jpg", "129111.jpg", "161752.jpg", "165520.jpg",
  "195411.jpg", "221256.jpg", "239499.jpg", "26715.jpg", "267997.jpg",
  "398037.jpg", "41287.jpg", "435462.jpg", "450344.jpg",
  "511479.jpg", "561537.jpg", "563423.jpg", "566774.jpg", "583733.jpg",
  "587816.jpg", "652351.jpg", "655142.jpg", "702762.jpg", "726267.jpg",
  "733715.jpg", "808033.jpg", "811507.jpg", "813070.jpg", "820099.jpg",
  "82443.jpg", "82517.jpg", "829353.jpg", "840160.jpg", "850163.jpg",
  "872161.jpg", "964003.jpg", "969723.jpg", "991940.jpg",
  "4te2SyLtyy_2026_02_26_00_35_49.jpg",
  "38JUNjzjpe_2026_02_26_00_34_52.jpg",
  "MrqnDBCWl8_2026_02_26_00_33_55.jpg",
  "Rdi2gBKUJ0_2026_02_26_00_33_30.jpg",
  "PmsH1ySg2g_2026_02_26_00_32_46.jpg",
  "gHk6potBRG_2026_02_26_00_31_47.jpg",
  "ixZkbQ1oub_2026_02_26_00_31_11.jpg",
  "47ko8Ox3i4_2026_02_26_00_29_45.jpg",
  "ANLhGPVENk_2026_02_26_00_29_47.jpg",
  "K3Us23aR5F_2026_02_26_00_28_51.jpg",
  "ECb7Og7GJK_2026_02_26_00_27_45.jpg",
  "gslrWzpH5c_2026_02_26_00_26_24.jpg",
  "Ff71JfD3u6_2026_02_26_00_25_47.jpg",
  "KUq8ZsORXK_2026_02_26_00_25_11.jpg",
  "3jKXGVmkuA_2026_02_26_00_25_44.jpg",
  "B6wmkp5yGp_2026_02_26_00_25_08.jpg",
  "u7uZDJD20V_2026_02_26_00_25_05.jpg",
  "NxmQcoiRUH_2026_02_26_00_25_02.jpg",
  "8XHkTaGUBf_2026_02_26_00_21_16.jpg",
  "ItChfVimfm_2026_02_26_00_19_52.jpg"
];
const keywords = "Photo Gallery, School Events, Student Life, Campus Photos, KNHS Gallery, School Activities Images";
---

<BaseLayout title="Gallery" description={description} keywords={keywords}>
  <span slot="head">
    <style>
      main { max-width: 1200px; }

      .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.85);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
      }

      .modal-content {
        position: relative;
        max-width: 90vw;
        max-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .modal-content img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 4px;
      }

      .modal-close {
        position: absolute;
        top: 15px;
        right: 15px;
        width: 50px;
        height: 50px;
        background-color: #fec90d;
        color: #012f63;
        border: none;
        border-radius: 50%;
        font-size: 32px;
        font-weight: bold;
        cursor: pointer;
        z-index: 1001;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(254, 201, 13, 0.4);
      }

      .modal-close:hover {
        background-color: #ffd633;
        transform: rotate(90deg) scale(1.1);
        box-shadow: 0 6px 16px rgba(254, 201, 13, 0.6);
      }

      .modal-close:active {
        transform: rotate(90deg) scale(0.95);
      }

      .modal-share {
        position: absolute;
        top: 15px;
        right: 75px;
        width: 50px;
        height: 50px;
        background-color: #fec90d;
        color: #012f63;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        z-index: 1001;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(254, 201, 13, 0.4);
      }

      .modal-share:hover {
        background-color: #ffd633;
        transform: scale(1.1);
        box-shadow: 0 6px 16px rgba(254, 201, 13, 0.6);
      }

      .modal-share:active {
        transform: scale(0.95);
      }

      .gallery-item {
        position: relative;
        overflow: hidden;
        border-radius: 8px;
      }

      .gallery-item:hover .share-overlay {
        opacity: 1;
      }

      .share-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.28);
        display: flex;
        align-items: flex-start;
        justify-content: flex-end;
        padding: 8px;
        gap: 8px;
        opacity: 0;
        transition: opacity 0.18s ease, background-color 0.18s ease;
        z-index: 100;
        pointer-events: none;
      }

      .share-btn {
        width: 44px;
        height: 44px;
        background-color: #fec90d;
        color: #012f63;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, background-color 0.2s ease, opacity 0.2s ease;
        opacity: 0;
        transform: scale(0.92);
        box-shadow: 0 4px 12px rgba(254, 201, 13, 0.35);
      }

      .gallery-item:hover .share-btn {
        opacity: 1;
        transform: scale(1);
      }

      .share-btn {
        pointer-events: auto;
      }

      .share-btn svg {
        width: 20px;
        height: 20px;
        fill: #012f63;
        display: block;
      }

      .share-btn:active { transform: scale(0.95); }
    </style>
  </span>

  <section>
    <h2>School Gallery</h2>
    <p>Moments captured around our campus.</p>
    <div class="gallery-grid">
      {images.map(img => (
        <div class="gallery-item">
          <img src={`/assets/images/gallery/${img}`} alt="Gallery Image" loading="lazy" class="gallery-image" style="cursor: pointer;">
          <div class="share-overlay">
            <button class="share-btn" data-image={img} onclick="shareImage(this, this.getAttribute('data-image'))" aria-label="Share image">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.02-4.11c.54.5 1.25.81 2.07.81 1.66 0 3-1.34 3-3S19.66 2 18 2s-3 1.34-3 3c0 .24.04.47.09.7L8.07 9.81C7.54 9.31 6.83 9 6 9 4.34 9 3 10.34 3 12s1.34 3 3 3c.83 0 1.54-.31 2.07-.81l7.12 4.05c-.05.21-.09.43-.09.66 0 1.66 1.34 3 3 3s3-1.34 3-3-1.34-2.92-3-2.92z"/>
              </svg>
            </button>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div id="imageModal" class="modal" style="display: none;">
    <div class="modal-content">
      <button class="modal-share" aria-label="Share image">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" width="24" height="24" fill="currentColor">
            <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.02-4.11c.54.5 1.25.81 2.07.81 1.66 0 3-1.34 3-3S19.66 2 18 2s-3 1.34-3 3c0 .24.04.47.09.7L8.07 9.81C7.54 9.31 6.83 9 6 9 4.34 9 3 10.34 3 12s1.34 3 3 3c.83 0 1.54-.31 2.07-.81l7.12 4.05c-.05.21-.09.43-.09.66 0 1.66 1.34 3 3 3s3-1.34 3-3-1.34-2.92-3-2.92z"/>
          </svg>
      </button>
      <span class="modal-close">&times;</span>
      <img id="modalImage" src="" alt="Enlarged view">
    </div>
  </div>

  <script is:inline>
    function shuffleGallery() {
      const grid = document.querySelector('.gallery-grid');
      if (grid) {
        const nodes = Array.from(grid.children);
        nodes.sort(() => Math.random() - 0.5);
        nodes.forEach(node => grid.appendChild(node));
      }
    }

    // Share image function
    function shareImage(button, imageInput) {
      const imageName = imageInput || button.getAttribute('data-image');
      const imagePath = `gallery/${imageName}`;

      // Encode path as base64 for compact/safe sharing in the URL
      let encoded;
      try {
        encoded = btoa(imagePath);
      } catch (e) {
        // Fallback for any unexpected encoding problems
        encoded = encodeURIComponent(imagePath);
      }

      const shareUrl = `${window.location.origin}/view?image=${encodeURIComponent(encoded)}`;

      // Copy to clipboard
      navigator.clipboard.writeText(shareUrl).then(() => {
        const originalContent = button.innerHTML;
        const originalBg = button.style.backgroundColor;
        
        button.innerHTML = '✓';
        button.style.backgroundColor = '#4caf50';

        setTimeout(() => {
          button.innerHTML = originalContent;
          button.style.backgroundColor = originalBg;
        }, 2000);
      }).catch(() => {
        alert('Failed to copy. Share URL: ' + shareUrl);
      });
    }

    // Initialize lightbox functionality
    function initLightbox() {
      const modal = document.getElementById('imageModal');
      const modalImage = document.getElementById('modalImage');
      const modalClose = document.querySelector('.modal-close');
      const modalShare = document.querySelector('.modal-share');
      const galleryImages = document.querySelectorAll('.gallery-image');

      // Open modal on image click
      galleryImages.forEach(img => {
        img.addEventListener('click', function() {
          modal.style.display = 'flex';
          modalImage.src = this.src;
          const fileName = this.src.split('/').pop();
          modalShare.setAttribute('data-image', fileName);
          document.body.style.overflow = 'hidden';
        });

        // Context menu listener for quick sharing
        img.addEventListener('contextmenu', function(e) {
          e.preventDefault();
          const fileName = this.src.split('/').pop();
          
          // Use the shareImage logic to copy URL
          const dummyButton = document.createElement('button');
          shareImage(dummyButton, fileName);
          
          // Toast notification
          const toast = document.createElement('div');
          toast.textContent = '📋 Share link copied!';
          toast.style.cssText = 'position:fixed; bottom:80px; left:50%; transform:translateX(-50%); background:#012f63; color:#fec90d; padding:12px 24px; border-radius:25px; z-index:10000; font-weight:bold; box-shadow:0 8px 16px rgba(0,0,0,0.3); animation: fadeUp 0.3s ease-out;';
          
          if (!document.getElementById('toast-style')) {
            const style = document.createElement('style');
            style.id = 'toast-style';
            style.innerHTML = `@keyframes fadeUp { from { opacity: 0; transform: translate(-50%, 20px); } to { opacity: 1; transform: translate(-50%, 0); } }`;
            document.head.appendChild(style);
          }
          
          document.body.appendChild(toast);
          setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transition = 'opacity 0.5s ease';
            setTimeout(() => toast.remove(), 500);
          }, 2000);
        });
      });

      // Also add to modal image
      modalImage.addEventListener('contextmenu', function(e) {
        e.preventDefault();
        const fileName = this.src.split('/').pop();
        const dummyButton = document.createElement('button');
        shareImage(dummyButton, fileName);
        
        const toast = document.createElement('div');
        toast.textContent = '📋 Share link copied!';
        toast.style.cssText = 'position:fixed; bottom:80px; left:50%; transform:translateX(-50%); background:#012f63; color:#fec90d; padding:12px 24px; border-radius:25px; z-index:10000; font-weight:bold; box-shadow:0 8px 16px rgba(0,0,0,0.3); animation: fadeUp 0.3s ease-out;';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2500);
      });

      // Handle modal share button
      modalShare.addEventListener('click', function() {
        shareImage(this);
      });

      // Close modal on close button click
      modalClose.addEventListener('click', function() {
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
      });

      // Close modal on outside click
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          modal.style.display = 'none';
          document.body.style.overflow = 'auto';
        }
      });

      // Close modal on ESC key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.style.display === 'flex') {
          modal.style.display = 'none';
          document.body.style.overflow = 'auto';
        }
      });
    }

    // Run on initial load
    shuffleGallery();
    initLightbox();

    // Support for Astro view transitions
    document.addEventListener('astro:after-swap', function() {
      shuffleGallery();
      initLightbox();
    });
  </script>
</BaseLayout>
